# Connection string to your managed MySQL database (e.g., PlanetScale, AWS RDS, Aiven)
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=mysql+pymysql://username:secure_password@cloud-db-host.com:3306/resume_db

# A long random string for JWT signing. Generate one using: openssl rand -hex 32
SECRET_KEY=generate_a_secure_random_key_here

# URL of your deployed Vercel frontend (for CORS)
FRONTEND_URL=https://your-vercel-app.vercel.app
